{
  "name": "lailai",
  "version": "0.0.0",
  "description": "lailai's personal website for technical notes, projects, and learning",
  "private": true,
  "license": "MIT",
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "start:zh-Hans": "docusaurus start --locale zh-Hans",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-translations:zh-Hans": "docusaurus write-translations --locale zh-Hans",
    "write-heading-ids": "docusaurus write-heading-ids",
    "i18n": "docusaurus write-translations --locale zh-Hans",
    "format": "npx prettier --write . '!**/.agents/skills/lailai-skill/**'",
    "lint": "eslint src",
    "typecheck": "tsc",
    "check": "npm run i18n && npm run format && npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.2",
    "@docusaurus/faster": "^3.10.2",
    "@docusaurus/preset-classic": "^3.10.2",
    "@docusaurus/remark-plugin-npm2yarn": "^3.10.2",
    "@docusaurus/theme-live-codeblock": "^3.10.2",
    "@docusaurus/theme-mermaid": "^3.10.2",
    "@fontsource/inter": "^5.2.8",
    "@giscus/react": "^3.0.0",
    "@iconify/react": "^6.0.0",
    "@mdx-js/react": "^3.0.0",
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.0.0",
    "color": "^5.0.0",
    "d3-geo": "^3.1.1",
    "docusaurus-plugin-image-zoom": "^3.0.1",
    "i18n-iso-countries": "^7.14.0",
    "katex": "^0.16.47",
    "prism-react-renderer": "^2.4.0",
    "raw-loader": "^4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-globe.gl": "^2.37.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "rough-notation": "^0.5.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.2",
    "@docusaurus/tsconfig": "^3.10.2",
    "@docusaurus/types": "^3.10.2",
    "@eslint/js": "^10.0.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.6.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
