{
  "name": "lailai",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "start:zh-Hans": "docusaurus start --locale zh-Hans",
    "start:zh-Hant": "docusaurus start --locale zh-Hant",
    "start:ja": "docusaurus start --locale ja",
    "start:ko": "docusaurus start --locale ko",
    "start:es": "docusaurus start --locale es",
    "start:fr": "docusaurus start --locale fr",
    "start:ru": "docusaurus start --locale ru",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-translations:zh-Hans": "docusaurus write-translations --locale zh-Hans",
    "write-translations:zh-Hant": "docusaurus write-translations --locale zh-Hant",
    "write-translations:ja": "docusaurus write-translations --locale ja",
    "write-translations:ko": "docusaurus write-translations --locale ko",
    "write-translations:es": "docusaurus write-translations --locale es",
    "write-translations:fr": "docusaurus write-translations --locale fr",
    "write-translations:ru": "docusaurus write-translations --locale ru",
    "write-heading-ids": "docusaurus write-heading-ids",
    "i18n": "npm run write-translations:zh-Hans && npm run write-translations:ja && npm run write-translations:ko && npm run write-translations:es && npm run write-translations:fr && npm run write-translations:ru",
    "format": "npx prettier --write .",
    "typecheck": "tsc",
    "check": "npm run i18n && npm run format && npm run typecheck"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/faster": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@docusaurus/remark-plugin-npm2yarn": "3.10.0",
    "@docusaurus/theme-live-codeblock": "3.10.0",
    "@docusaurus/theme-mermaid": "3.10.0",
    "@giscus/react": "^3.0.0",
    "@iconify/react": "^6.0.0",
    "@mdx-js/react": "^3.0.0",
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.0.0",
    "color": "^5.0.0",
    "i18n-iso-countries": "^7.14.0",
    "mini-svg-data-uri": "^1.4.4",
    "prism-react-renderer": "^2.4.0",
    "raw-loader": "^4.0.2",
    "react": "^18.3.1",
    "react-chrono": "2.4.0",
    "react-dom": "^18.3.1",
    "react-globe.gl": "^2.37.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "rough-notation": "^0.5.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@mermaid-js/layout-elk": "^0.1.9",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "elkjs": "^0.11.0",
    "prettier": "^3.6.2",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
